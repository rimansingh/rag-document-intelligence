# LLM
GROQ_API_KEY=your_groq_api_key_here

# Database
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# App
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development

# Keep-alive (Hugging Face Spaces)
# Set this to your full HF Space URL so the backend pings itself to stay awake
HF_SPACE_URL=https://your-username-your-space-name.hf.space
KEEP_ALIVE_INTERVAL=600

# ChromaDB
CHROMA_PATH=./chroma_db

# Terraform (local dev only)
TF_VAR_groq_api_key=your_groq_api_key_here
TF_VAR_supabase_url=your_supabase_project_url
TF_VAR_supabase_key=your_supabase_anon_key